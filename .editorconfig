root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{py,rego,yml,yaml,json,md,toml,tf}]
indent_size = 2

[*.{go}]
indent_style = tab

[Makefile]
indent_style = tab

[*.{ps1,bat,cmd}]
end_of_line = crlf

[*.go]
trim_trailing_whitespace = false
